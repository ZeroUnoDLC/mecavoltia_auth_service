# ─────────────────────────────────────────────────────────────────────────────
# Plantilla de entorno del auth_service.
#
#   cp .env.example .env
#
# SOLO se usa al correr el servicio o Prisma DESDE EL HOST (migraciones, seed,
# prisma studio). Dentro de Docker las variables llegan desde el compose y este
# archivo se ignora.
#
# NO pongas valores reales acá: este archivo SE VERSIONA. Para tu .env local usá
# el password de dev que está como default en docker-compose.dev.yml.
# ─────────────────────────────────────────────────────────────────────────────

# Conexión a la database propia del servicio.
DATABASE_URL=postgresql://mecavoltia_auth_user:<DEV_DB_PASSWORD>@localhost:5432/mecavoltia_auth

PORT=3000

# Claves RS256 de desarrollo — generarlas con: bash ../infra/scripts/generate-dev-keys.sh
JWT_PRIVATE_KEY_PATH=../infra/keys/private.pem
JWT_PUBLIC_KEY_PATH=../infra/keys/public.pem
JWT_KID=mecavoltia-dev-1

# issuer/audience: deben coincidir con lo que valida web_back al leer el JWKS
JWT_ISSUER=https://mecavoltia.com
JWT_AUDIENCE=mecavoltia

# TTL de tokens: access corto (15 min), refresh largo (7 días) con rotación
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# Contraseñas iniciales del seed de los 3 socios. Completar en tu .env local
# (dev) y con secrets fuertes en el .env del server (prod). NUNCA acá.
SEED_PASSWORD_CRISTHIAN=
SEED_PASSWORD_FERNANDO=
SEED_PASSWORD_BRAYAN=
